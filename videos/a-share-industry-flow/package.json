{
  "name": "a-share-industry-flow-remotion",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "data:fetch": "python3 scripts/fetch_industry_flow.py",
    "studio": "remotion studio src/index.ts",
    "typecheck": "tsc --noEmit",
    "build": "remotion compositions src/index.ts",
    "render": "remotion render src/index.ts AShareIndustryFundFlow out/a-share-industry-flow-2026-07-17-compatible.mp4 --codec=h264 --crf=18 --pixel-format=yuv420p --color-space=bt709 --muted",
    "still:title": "remotion still src/index.ts AShareIndustryFundFlow previews/00-title.png --frame=18",
    "still:inflow": "remotion still src/index.ts AShareIndustryFundFlow previews/01-inflow.png --frame=125",
    "still:outflow": "remotion still src/index.ts AShareIndustryFundFlow previews/02-outflow.png --frame=235",
    "still:outro": "remotion still src/index.ts AShareIndustryFundFlow previews/03-outro.png --frame=285",
    "stills": "npm run still:title && npm run still:inflow && npm run still:outflow && npm run still:outro"
  },
  "dependencies": {
    "@remotion/cli": "4.0.490",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "remotion": "4.0.490",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "typescript": "5.9.3"
  }
}
