        <mxCell id="n2" value="ETF 多头趋势图 | 2026-07-20&#xa;基于完整 JSON rows，仅筛选 trend = 多头" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontFamily=Helvetica;fontSize=24;fontStyle=1;fontColor=#111827;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="900" height="60" as="geometry" /></mxCell> <mxCell id="n3" value="完整 JSON 数据&#xa;rows = 68&#xa;来源: representative technical review" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=14;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="100" width="300" height="90" as="geometry" /></mxCell> <mxCell id="n4" value="筛选条件&#xa;trend == 多头&#xa;保留完整指标字段" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=14;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="390" y="100" width="280" height="90" as="geometry" /></mxCell> <mxCell id="n5" value="筛选结果&#xa;5 只 ETF&#xa;技术候选 3 | 不追涨 2" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=14;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="720" y="100" width="300" height="90" as="geometry" /></mxCell> <mxCell id="n6" value="交易闸门&#xa;本图是筛选与解释，不是买入指令。正式提醒前仍需核对实时溢折价、相对强度、一级来源催化和风险事件。" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontFamily=Helvetica;fontSize=11;spacingLeft=12;spacingRight=12;spacingTop=10;spacingBottom=8;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1080" y="85" width="620" height="120" as="geometry" /></mxCell> <mxCell id="e7" value="读取" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#6b7280;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="n3" target="n4"><mxGeometry